# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# -----------------------------------------------------------------------
# Chess.com OAuth 2.0 PKCE (optional — enables per-user login button)
#
# Register your application at https://www.chess.com/club/chess-com-developer-community
# to obtain a Client ID. Set the redirect URI to match OAUTH_REDIRECT_URI below.
# -----------------------------------------------------------------------
CHESSCOM_OAUTH_CLIENT_ID=
OAUTH_REDIRECT_URI=http://localhost:5000/auth/callback

# -----------------------------------------------------------------------
# Chess.com server credentials (recommended — required for tournaments,
# leaderboard, matchups, attendance, and records)
#
# The Chess.com internal API uses session cookies, not OAuth tokens.
# Obtain these by logging into chess.com in your browser and copying
# the ACCESS_TOKEN and PHPSESSID cookies (expires: ~24h / ~2 weeks).
#
# Use the chessclub Cookie Helper extension (tools/chessclub-cookie-helper/)
# or copy manually from DevTools > Application > Cookies > chess.com.
# -----------------------------------------------------------------------
CHESSCOM_SERVER_ACCESS_TOKEN=
CHESSCOM_SERVER_PHPSESSID=

# -----------------------------------------------------------------------
# Background sync worker
# -----------------------------------------------------------------------
# Interval (hours) between automatic cache sync runs (default: 6)
SYNC_INTERVAL_HOURS=6
# Password to access the /admin dashboard (leave empty to disable admin)
ADMIN_PASSWORD=

# -----------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------
# SQLAlchemy database URI (default: SQLite in instance/chessclub.db)
# DATABASE_URI=sqlite:///chessclub.db
